# Copy to a private env file outside the repository, for example:
# /etc/awiki-open-server/awiki-open-server.env

AWIKI_DATA_DIR=/var/lib/awiki-open-server
AWIKI_PUBLIC_BASE_URL=https://rwiki.cn
AWIKI_DID_DOMAIN=rwiki.cn
AWIKI_SERVICE_DID=did:wba:rwiki.cn
AWIKI_SERVICE_PRIVATE_KEY_PATH=/etc/awiki-open-server/rwiki-service-ed25519.pem
AWIKI_IM_RPC_PATH=/im/rpc
AWIKI_ANP_PUBLIC_RPC_PATH=/anp-im/rpc
AWIKI_WS_PATH=/im/ws
AWIKI_OBJECT_UPLOAD_PATH=/objects/upload
AWIKI_OBJECT_DOWNLOAD_PATH=/objects
AWIKI_MAX_ATTACHMENT_BYTES=10485760
AWIKI_ATTACHMENT_ALLOWED_MIME_TYPES=application/anp-attachment-manifest+json,application/json,application/octet-stream,application/pdf,image/gif,image/jpeg,image/png,text/plain

# Keep this disabled for real awiki.info interoperability.
AWIKI_ALLOW_UNSIGNED_PEER_DEV=false

# v0.1 does not use email or phone verification. Keep legacy local contact
# verification shims disabled in public deployments.
AWIKI_ENABLE_CONTACT_VERIFICATION_COMPAT=false
